# ═══════════════════════════════════
# RIGHTROAM — Variables d'environnement
# ═══════════════════════════════════
# Copiez ce fichier en .env et remplissez les valeurs

# Serveur
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/rightroam

# Sécurité JWT
JWT_SECRET=votre_secret_jwt_très_long_et_sécurisé_ici

# Stripe (paiements carte bancaire)
# Obtenez vos clés sur https://stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
# Obtenez vos clés sur https://developer.paypal.com
PAYPAL_CLIENT_ID=votre_client_id_paypal
PAYPAL_SECRET=votre_secret_paypal
PAYPAL_MODE=sandbox

# Google Maps (géolocalisation)
# Obtenez votre clé sur https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=votre_clé_google_maps

# AWS S3 (stockage photos de profil)
AWS_ACCESS_KEY_ID=votre_access_key
AWS_SECRET_ACCESS_KEY=votre_secret_key
AWS_BUCKET_NAME=rightroam-uploads
AWS_REGION=eu-west-1

# Firebase (notifications push)
FIREBASE_PROJECT_ID=rightroam-app
FIREBASE_PRIVATE_KEY=votre_clé_firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@rightroam.iam.gserviceaccount.com
